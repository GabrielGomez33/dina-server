{
  "name": "dina-server",
  "version": "1.0.0",
  "description": "DINA Distributed Intelligence Neural Architect - Backend System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "start:pm2": "sudo pm2 start ecosystem.config.js",
    "stop": "sudo pm2 stop dina-server",
    "restart": "sudo pm2 restart dina-server",
    "reload": "sudo pm2 reload dina-server",
    "logs": "sudo pm2 logs dina-server",
    "status": "sudo pm2 status",
    "monit": "sudo pm2 monit",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "deploy": "npm run rebuild && sudo pm2 reload ecosystem.config.js",
    "migrate": "ts-node scripts/migrate.ts up",
    "migrate:status": "ts-node scripts/migrate.ts status",
    "migrate:list": "ts-node scripts/migrate.ts list",
    "migrate:down": "ts-node scripts/migrate.ts down",
    "test": "jest",
    "test:digim": "ts-node test/digim/webEdgeCases.ts",
    "test:gpu": "ts-node src/modules/gpu/tests/gpuArbiterTest.ts",
    "test:saga": "ts-node src/modules/saga/tests/sagaFoundationTest.ts",
    "test:saga:render": "ts-node src/modules/saga/tests/renderSystemsTest.ts",
    "test:saga:routes": "ts-node src/modules/saga/tests/routeContractTest.ts",
    "test:saga:prompt": "ts-node src/modules/saga/tests/promptSystemsTest.ts",
    "test:saga:models": "ts-node src/modules/saga/tests/modelRegistryTest.ts",
    "test:saga:fidelity": "ts-node src/modules/saga/tests/fidelityTest.ts",
    "test:saga:worker": "ts-node src/modules/saga/tests/generationWorkerTest.ts",
    "test:saga:lora": "ts-node src/modules/saga/tests/loraTrainingTest.ts",
    "test:saga:framerate": "ts-node src/modules/saga/tests/framerateTest.ts",
    "test:saga:cine": "ts-node src/modules/saga/tests/cinematographyTest.ts",
    "test:saga:timeline": "ts-node src/modules/saga/tests/timelineTest.ts",
    "test:migration": "ts-node test/digim/migrationTest.ts",
    "test:memory": "ts-node test/digim/memoryTest.ts",
    "test:tools": "ts-node test/digim/toolTest.ts",
    "test:sources": "ts-node test/digim/sourceTest.ts",
    "test:planner": "ts-node test/digim/plannerTest.ts",
    "test:graph": "ts-node test/digim/graphTest.ts",
    "test:history": "ts-node test/digim/historyTest.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "AI",
    "neural",
    "intelligence",
    "distributed"
  ],
  "author": "DINA Development Team",
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/node-fetch": "^2.6.2",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "linkedom": "^0.18.13",
    "morgan": "^1.10.0",
    "mysql2": "^3.14.1",
    "node-fetch": "^2.6.7",
    "redis": "^5.6.0",
    "redis-om": "^0.4.7",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.4",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "playwright-core": "^1.55.0"
  }
}
