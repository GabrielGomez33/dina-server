# diffusion-pipe HUNYUAN-VIDEO video-LoRA config (template) — used by the FramePack backend.
# VERIFY-LIVE (verified against models/hunyuan_video.py in the installed diffusion-pipe):
#   THIS version loads the ORIGINAL Tencent HunyuanVideo layout via a single `ckpt_path` base
#   dir — NOT Kijai single-file safetensors. The loader hard-derives:
#     transformer := <ckpt_path>/hunyuan-video-t2v-720p/transformers/mp_rank_00_model_states.pt
#     vae         := <ckpt_path>/hunyuan-video-t2v-720p/vae            (default; or set vae_path)
#     llm (llava) := <ckpt_path>/text_encoder                          (default; or set llm_path)
#     clip-l      := <ckpt_path>/text_encoder_2                        (default; or set clip_path)
#   So the ONLY required model key is `ckpt_path`. Download the tree with the commands in
#   docs/VIDEO_BACKENDS.md §2 (official Tencent flow + the llava text-encoder preprocess step).
output_dir = '@OUTPUT_DIR@'
dataset = '@DATASET_TOML@'
# Recompute activations in backward instead of storing them — the decisive 24GB saver.
# Without this, the forward pass OOMs even with block-swapping. Verified required on a 3090 Ti.
activation_checkpointing = true

epochs = @EPOCHS@
micro_batch_size_per_gpu = 1
gradient_accumulation_steps = 4
gradient_clipping = 1.0
warmup_steps = 100
save_every_n_epochs = @SAVE_EVERY@
checkpoint_every_n_minutes = 30
blocks_to_swap = 10            # offload N transformer blocks to CPU RAM. With
                               # activation_checkpointing on, the model fits 24GB with LITTLE
                               # swapping — 30 was over-conservative (left ~13GB idle and made
                               # every step wait on PCIe). TUNE via nvidia-smi during a run:
                               # if VRAM stays well under ~21GB, drop toward 0 (fastest, no swap);
                               # only raise this if you actually OOM. Fewer swaps = faster steps.

[model]
type = 'hunyuan-video'
# Base dir containing hunyuan-video-t2v-720p/{transformers,vae}/, text_encoder/, text_encoder_2/
ckpt_path = '@MODEL_ROOT@/hunyuan-video'
dtype = 'bfloat16'
transformer_dtype = 'float8'   # loads the bf16 transformer, quantizes to fp8 in-memory for 24GB
# Optional explicit overrides — only if you placed encoders/vae outside the ckpt tree above:
# vae_path  = '@MODEL_ROOT@/hunyuan-video/hunyuan-video-t2v-720p/vae'
# llm_path  = '@MODEL_ROOT@/hunyuan-video/text_encoder'
# clip_path = '@MODEL_ROOT@/hunyuan-video/text_encoder_2'

[adapter]
type = 'lora'
rank = @RANK@
dtype = 'bfloat16'

[optimizer]
type = 'adamw_optimi'
lr = @LR@
betas = [0.9, 0.99]
weight_decay = 0.01
