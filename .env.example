# ============================================================================
# DINA SERVER — ENVIRONMENT TEMPLATE
# ============================================================================
# Copy to .env (gitignored) and fill in real values. Values that name
# infrastructure or secrets are NEVER committed. Registry with consumers,
# defaults, and effect timing: src/modules/saga/docs/ENVIRONMENT.md
# (Pre-existing variables — DB_*, REDIS_URL, DINA_PORT, TLS paths, DINA_*
#  LLM tuning — continue to live in your real .env as they always have.)
# ============================================================================

# ---- SAGA (image/video generation limb) ----
# REQUIRED. Absolute root of SAGA storage on the dedicated SSD.
# The saga module degrades (isolated, non-fatal) with a clear error if unset.
SAGA_ROOT=/absolute/path/to/saga/storage

# ---- GPU arbiter (cross-engine VRAM scheduler) ----
# off = dark launch (registered, zero request-path change) | on = enforcing.
# Flipping back to off + pm2 reload is the instant rollback.
DINA_GPU_ARBITER=off
# VRAM headroom (MB) the arbiter always keeps free. Read once at startup.
DINA_GPU_RESERVE_MB=512
