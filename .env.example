# ============================================================================
# DINA SERVER — ENVIRONMENT TEMPLATE
# ============================================================================
# Copy to .env (gitignored) and fill in real values. Values that name
# infrastructure or secrets are NEVER committed. Registry with consumers,
# defaults, and effect timing: src/modules/saga/docs/ENVIRONMENT.md
# (Pre-existing variables — DB_*, REDIS_URL, DINA_PORT, TLS paths, DINA_*
#  LLM tuning — continue to live in your real .env as they always have.)
# ============================================================================

# ---- SAGA (image/video generation limb) ----
# REQUIRED. Absolute root of SAGA storage on the dedicated SSD.
# The saga module degrades (isolated, non-fatal) with a clear error if unset.
SAGA_ROOT=/absolute/path/to/saga/storage

# ---- GPU arbiter (cross-engine VRAM scheduler) ----
# off = dark launch (registered, zero request-path change) | on = enforcing.
# Flipping back to off + pm2 reload is the instant rollback.
DINA_GPU_ARBITER=off
# VRAM headroom (MB) the arbiter always keeps free. Read once at startup.
DINA_GPU_RESERVE_MB=512

# ---- AUTH (DINA console user accounts) ----
# The users table is SHARED with mirror-server; DINA reuses it (see
# migrations/004_auth_users.ts). These secrets are DINA's OWN — deliberately
# DIFFERENT from mirror-server's, so a DINA token is not valid on Mirror and
# vice versa. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED (auth calls throw a clear 500 until both are set, ≥32 chars, distinct).
JWT_SECRET=
JWT_REFRESH_SECRET=
# Token lifetimes. Access is short (re-minted via /auth/refresh); refresh bounds
# how long a device stays signed in. refreshTokenTtlMs in config.ts mirrors 7d.
AUTH_ACCESS_TOKEN_EXPIRY=15m
AUTH_REFRESH_TOKEN_EXPIRY=7d
# bcrypt cost factor (10–15). 12 is a good default; matches mirror-server.
AUTH_BCRYPT_ROUNDS=12
# Absolute base URL of the DINA frontend — used to build verify/reset links in
# emails. No trailing slash. (Prod example shown.)
AUTH_APP_BASE_URL=https://www.theundergroundrailroad.world/dina
# Transactional email. 'console' (default) just logs the link — perfect for dev
# and safe by default (no accidental real sends). 'resend' posts to Resend.
AUTH_EMAIL_PROVIDER=console
RESEND_API_KEY=
AUTH_EMAIL_FROM=DINA <no-reply@theundergroundrailroad.world>
